APP_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
DATABASE_MODE=memory
DATABASE_URL=postgres://postgres:password@localhost:5432/tandaza?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_TTL_HOURS=168
LOG_LEVEL=info
EXPO_LIFECYCLE_WORKER_ENABLED=true
EXPO_LIFECYCLE_INTERVAL_SECONDS=3600

# Optional first administrator bootstrap. Set these in a fresh environment,
# start the API once, then rotate/remove the password from runtime env.
BOOTSTRAP_ADMIN_EMAIL=admin@tandaza.local
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
BOOTSTRAP_ADMIN_NAME=Platform Administrator
BOOTSTRAP_ADMIN_COMPANY=Tandaza
